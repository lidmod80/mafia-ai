# ════════════════════════════════════════════════════════════════
#  این فایل فقط برای قابلیت‌های سمت‌سرور آینده لازم است
#  (مثلاً گردانندهٔ هوش مصنوعی با Edge Function).
#
#  خودِ سایت استاتیک به این فایل نیاز ندارد؛ آدرس و کلید anon عمومی
#  Supabase در js/config.js قرار می‌گیرند.
#
#  این فایل را به .env کپی کن. .env در .gitignore است و کامیت نمی‌شود.
# ════════════════════════════════════════════════════════════════

SUPABASE_URL=
SUPABASE_ANON_KEY=

# هرگز سمت‌کلاینت قرار نده — فقط سرور / Edge Function:
SUPABASE_SERVICE_ROLE_KEY=

# برای گردانندهٔ اختیاری Claude (سمت‌سرور):
ANTHROPIC_API_KEY=
